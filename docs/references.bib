% Informative Sources

@article{shlens2014tutorial,
  author    = {Shlens, Jonathon},
  title     = {A Tutorial on Principal Component Analysis},
  journal   = {arXiv preprint arXiv:1404.1100},
  year      = {2014},
  note      = {Available at \url{https://arxiv.org/abs/1404.1100}},
  annotation = {PCA is a mainstay of modern data analysis but often poorly understood. This tutorial teaches the mathematical foundations of PCA, to dispel the "magic behind the black box". Shlens covers both the informal ideas and the formal mathematics behind PCA.
  
  This is the main source for understanding how and why PCA works in my project. The step-by-step derivation from intuition to math is useful for the mathematical foundations section, and the discussion of when to apply PCA helps identify potential issues with text data.}
}

@misc{jakkula2011svm,
  author       = {Jakkula, Vikramaditya},
  title        = {Tutorial on Support Vector Machine ({SVM})},
  year         = {2011},
  institution  = {School of EECS, Washington State University},
  url          = {https://course.ccs.neu.edu/cs5100f11/resources/jakkula.pdf},
  note         = {Accessed: 2026-02-09},
  annotation   = {This tutorial introduces SVM starting with statistical learning theory, then presents the mathematical formulation and implementation. SVMs use Structural Risk Minimization (SRM) rather than the Empirical Risk Minimization (ERM) used by neural networks---SRM minimizes an upper bound on expected risk rather than just training error, which gives SVMs better generalization.
  
  This source explains why SVMs work well on high-dimensional data, which is directly relevant to the text classification problem. The comparison to neural networks and the discussion of generalization connects to my project's question of whether PCA preprocessing helps or hurts SVM performance.}
}




